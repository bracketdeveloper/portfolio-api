RewriteEngine On

# Stop processing if the request matches an actual file or directory
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all traffic to api/index.php and pass the path as a 'route' parameter
RewriteRule ^api/(.*)$ api/index.php?route=$1 [L,QSA]